# ─── Supabase ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Tenant / Brand ────────────────────────────
NEXT_PUBLIC_BRAND_USERNAME=your-brand-username
# BRAND_USERNAME=              # server-side override (optional)
# SITE_URL=                    # defaults to https://www.<username>.com
# NEXT_PUBLIC_SITE_URL=        # client-side override
# SITE_NAME=                   # defaults to username
# NEXT_PUBLIC_SITE_NAME=
# CONTACT_EMAIL=               # defaults to contact@<username>.com
# NEXT_PUBLIC_CONTACT_EMAIL=
# CONTACT_PHONE=
# NEXT_PUBLIC_CONTACT_PHONE=

# ─── Email (Resend) ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@doubleclicker.app
# NOTIFICATION_EMAIL=          # override for lead-capture notifications

# ─── Analytics ──────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# GA_ID=                       # server-side override
# GTM_ID=                      # server-side override
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Google Services (Provisioning) ────────────
# GOOGLE_SERVICE_ACCOUNT_JSON=  # full JSON key for SA
# GOOGLE_CLOUD_PROJECT=gen-lang-client-0071841353
# GOOGLE_ANALYTICS_ACCOUNT_ID=
# GOOGLE_TAG_MANAGER_ACCOUNT_ID=

# ─── AI / LLM ──────────────────────────────────
# OPENAI_API_KEY=              # used by AI features
# FAL_API_KEY=                 # used for image generation

# ─── Fly.io Deployment ─────────────────────────
# FLY_API_TOKEN=
# FLY_ORG_SLUG=personal
# FLY_BASE_APP=doubledoubleclickclick

# ─── Provisioning ──────────────────────────────
# PROVISION_SECRET=            # shared auth token for provisioner
# DOUBLECLICKER_API_URL=https://doubleclicker.fly.dev

# Domain registration admin email (defaults to stuartr@sewo.io if not set)
# DOMAIN_ADMIN_EMAIL=
